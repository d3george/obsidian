			"link": null,
			"locked": false,
			"text": "Docker 方式注册 MCP：\n$ claude mcp add excalidraw --scope user -- \\\n  docker run -i --rm \\\n  -e EXPRESS_SERVER_URL=http://host.docker.internal:3000 \\\n  -e ENABLE_CANVAS_SYNC=true \\\n  ghcr.io/yctimlin/mcp_excalidraw:latest",
