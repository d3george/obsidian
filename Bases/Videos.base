model:
  version: 1
  kind: Table
  columns: []
pluginVersion: 1.0.0
filters:
  and:
    - file.tags.contains("source/video")
views:
  - type: cards
    name: 视图
    order:
      - file.name
      - author
    cardSize: 400
    image: note.cover
    imageFit: contain
    imageAspectRatio: 0.6
  - type: table
    name: 表格
